{
  "name": "demo",
  "services": {
    "db": {
      "image": "base",
      "command": "/bin/sh -c 'echo db-started && sleep 9999'",
      "restart": "always",
      "health_check": {
        "exec": "/bin/true",
        "interval_ms": 500,
        "retries": 3,
        "start_period_ms": 100
      }
    },
    "web": {
      "image": "base",
      "command": "/bin/sh -c 'echo web-started && sleep 9999'",
      "depends_on": ["db"],
      "restart": "on-failure",
      "health_check": {
        "exec": "/bin/true",
        "interval_ms": 500,
        "retries": 2,
        "start_period_ms": 100
      }
    }
  }
}
