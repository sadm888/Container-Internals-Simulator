# Enforce LF line endings for all source and script files
*.c     text eol=lf
*.h     text eol=lf
*.sh    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.html  text eol=lf
Makefile text eol=lf

# Compiled binaries — no line-ending conversion
*.o     binary
*.so    binary
container-sim binary
bin/*   binary
